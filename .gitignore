# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local PGlite data dir
/pgdata

# per-agent config — generated by `npm run agents:link` from .agents/.
# canonical sources live in .agents/{mcp.json,skills/}
.claude/
.codex/
.gemini/
.cursor/
.mcp.json
opencode.json

# playwright e2e
/pgdata-test
/.next-test
/test-results
/playwright-report
/.playwright-mcp
/playwright/.cache
/tests/e2e/.auth
/tests/e2e/.api-keys.json
