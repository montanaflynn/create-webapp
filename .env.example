# Optional locally — defaults to embedded PGlite at ./pgdata, no infra needed.
# In production set this to a Postgres URL (e.g. Neon).
DATABASE_URL=

BETTER_AUTH_SECRET=replace-me-run-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# Bootstrap admin: comma-separated user IDs that are always treated as admin,
# regardless of their `role` column. Useful when you can't run admin:promote.
# ADMIN_USER_IDS=user_abc,user_def

# Email — outgoing mail goes to the DB-inbox transport (browse at /dev/inbox)
# unless RESEND_API_KEY is set, in which case Resend is used.
# RESEND_API_KEY=re_...
# EMAIL_FROM="App <onboarding@yourdomain.com>"
# EMAIL_TRANSPORT_OVERRIDE=db-inbox  # force a transport regardless (db-inbox|resend|console)
# FORCE_TO_OVERRIDE=staging-admin@example.com  # rewrite every "to:" — staging safety net
